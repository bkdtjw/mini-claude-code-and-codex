# === Provider API Keys ===
ENABLE_TOOL_SEARCH=true
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_BASE_URL=
OPENAI_API_KEY=sk-xxx
OLLAMA_BASE_URL=http://localhost:11434

# === Default Model ===
DEFAULT_PROVIDER=anthropic
DEFAULT_MODEL=claude-sonnet-4-20250514

# === Server ===
API_HOST=127.0.0.1
API_PORT=8000
WS_PORT=8001

# === Database ===
DATABASE_URL=
# DATABASE_URL=postgresql+asyncpg://agent:password@localhost:5432/agent_studio
REDIS_URL=
# REDIS_URL=redis://localhost:6379/0

# === Auth ===
# Bearer token for management APIs. Must be changed in production.
AUTH_SECRET=change-me-in-production

# === Feishu (飞书)  1�7 单向通知 ===
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-token-here
FEISHU_WEBHOOK_SECRET=

# === Feishu (飞书)  1�7 双向通信（企业自建应用） ===
# 创建应用：https://open.feishu.cn ↄ1�7 企业自建应用
# 霢�弢�通权限：im:message:receive_v1, im:message:send_v1, im:chat:readonly
# 回调地址填：http://你的服务器IP:8000/api/feishu/event
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# 群聊 chat_id（用于定时任务卡片发送，支持按钮回调）
# 获取方式：在群设置中查看，或通过 API https://open.feishu.cn/open-apis/im/v1/chats 查询
FEISHU_CHAT_ID=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# === YouTube (optional) ===
# YouTube Data API v3 key（免费申请：https://console.cloud.google.com/apis/credentials＄1�7
# 每天免费配额 10,000 单位，一次搜索大约消耄1�7 101 单位
YOUTUBE_API_KEY=
# Proxy for YouTube subtitle extraction (required in China)
# Example: http://127.0.0.1:7890
YOUTUBE_PROXY_URL=

# === X/Twitter Search (optional) ===
# Uses twikit library to access Twitter's internal API
# Requires your X/Twitter account credentials
# Install: pip install twikit
TWITTER_USERNAME=
TWITTER_EMAIL=
TWITTER_PASSWORD=
# Proxy for accessing x.com (required in China)
# Example: http://127.0.0.1:7890
TWITTER_PROXY_URL=
# Cookie file path for session persistence (avoids re-login)
# For Docker deployment: place twitter_cookies.json in project root (same dir as docker-compose.yml)
# The container will mount it to /app/twitter_cookies.json
TWITTER_COOKIES_FILE=twitter_cookies.json

# === Proxy (mihomo) ===
MIHOMO_API_URL=http://127.0.0.1:9090
MIHOMO_SECRET=
MIHOMO_PATH=C:\mihomo\mihomo.exe
MIHOMO_CONFIG_PATH=C:\mihomo\config.yaml
MIHOMO_WORK_DIR=C:\mihomo
MIHOMO_SUB_PATH=C:\Users\nirvana\Desktop\agent-studio\sub_raw.yaml

# === Docker Deployment (Phase 3) ===
# Override API_PORT for parallel deployment (default: 8000)
# API_PORT=8001
# Host-network deployment keeps 127.0.0.1 pointing at the host machine.
# REDIS_URL=redis://127.0.0.1:6379/0
# Gunicorn workers (default: 4)
# GUNICORN_WORKERS=4
# === Sub Worker ===
SUB_WORKER_CONCURRENCY=2
# LOG_LEVEL=info
# LOG_FORMAT=json

# === Metrics ===
# METRICS_TTL_DAYS=30

# === Logging ===
# LOG_STDOUT=1
# LOG_FILE_ENABLED=1
# LOG_FILE_DIR=/app/data/logs
# LOG_FILE_RETENTION_DAYS=7
# LOG_FILE_SCOPE=worker
# LOG_SEARCH_BACKEND=file
# LOG_SEARCH_FALLBACK=file
# LOG_SEARCH_TRACE_MINUTES=10080
# LOKI_BASE_URL=http://127.0.0.1:3100
# LOKI_APP_LABEL=agent-studio
# LOKI_TENANT_ID=
# LOKI_QUERY_TIMEOUT_SECONDS=10
# LOKI_IMAGE=grafana/loki:3.7.1
# ALLOY_IMAGE=grafana/alloy:v1.15.1
# GRAFANA_IMAGE=grafana/grafana:13.0.1

# === Skills ===
# 默认从仓库根目录的 skills/ 加载
# SKILLS_DIR=skills

# === Notion MCP ===
NOTION_API_KEY=ntn_xxx
